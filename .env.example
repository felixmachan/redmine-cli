# Redmine API settings
REDMINE_BASE_URL=https://your-redmine.example.com
REDMINE_API_KEY=put-your-api-key-here
REDMINE_USER_ID=me
HTTP_USER_AGENT=curl/8.5.0
USE_CURL=1

# Optional manual date override for testing (YYYY-MM-DD).
# If both are empty:
# - on Windows, a month picker dialog opens (unless WINDOWS_MONTH_PICKER=0)
# - otherwise automatic range is used
#   day 1: previous full month
#   other days: current month up to today
DATE_FROM=
DATE_TO=
WINDOWS_MONTH_PICKER=1

# Excel settings
EXCEL_IN=unfilled.xlsx
EXCEL_OUT=filled.xlsx
SHEET_NAME=Munka1
ARRIVAL_TIME=09:00

# PDF export settings (only the big frame area)
PDF_OUT=filled.pdf
PDF_SAVE_DIALOG=1
PRINT_AREA=A1:F47
ALLOW_LIBREOFFICE_FALLBACK_ON_WINDOWS=0
COMPACT_EMPTY_ROWS=1

# Optional CLI v2 / TUI settings
DEFAULT_REDMINE_ACTIVITY_ID=9
NOTION_API_TOKEN=
NOTION_TASKS_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=
NOTION_DONE_STATUS_NAME=Done
NOTION_PROJECT_NAMES=
NOTION_WORK_PRIVATE_SCOPE=
NOTION_UPLOADED_FLAG_PROPERTY=
NOTION_REDMINE_ISSUE_PROPERTY=
